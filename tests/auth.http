### ── Login: ADMIN — copy token to @adminToken ────────────────
POST {{baseUrl}}/login
Content-Type: application/json

{
  "username": "admin",
  "password": "Admin123!"
}

### ── Login: COORDINATOR ──────────────────────────────────────
POST {{baseUrl}}/login
Content-Type: application/json

{
  "username": "coord1",
  "password": "Coord123!"
}

### ── Login: RESPONDER ────────────────────────────────────────
POST {{baseUrl}}/login
Content-Type: application/json

{
  "username": "resp1",
  "password": "Resp123!"
}

### ── Login: VOLUNTEER ────────────────────────────────────────
POST {{baseUrl}}/login
Content-Type: application/json

{
  "username": "vol1",
  "password": "Vol123!"
}

### ── Get own profile (needs token) ──────────────────────────
# Replace <TOKEN> with a token from the login responses above
@token = <TOKEN>

GET {{baseUrl}}/profile
Authorization: Bearer {{token}}

### ── Validate token ──────────────────────────────────────────
GET {{baseUrl}}/validate
Authorization: Bearer {{token}}
