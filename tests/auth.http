### Auth Service Tests
### PORT 8081 — No JWT required for register/login

@baseUrl = http://localhost:8081/api/auth

### ── Register: ADMIN ──────────────────────────────────────────
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "admin",
  "email": "admin@disa.local",
  "password": "Admin123!",
  "fullName": "System Admin",
  "role": "ADMIN"
}

### ── Register: COORDINATOR ───────────────────────────────────
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "coord1",
  "email": "coord1@disa.local",
  "password": "Coord123!",
  "fullName": "Jane Coordinator",
  "role": "COORDINATOR"
}

### ── Register: RESPONDER ─────────────────────────────────────
POST {{baseUrl}}/register
Content-Type: application/json

{
  "username": "resp1",
  "email": "resp1@disa.local",
  "password": "Resp123!",
  "fullName": "John Responder",
  "role": "RESPONDER"
}

### ── Register: VOLUNTEER ─────────────────────────────────────
POST {{baseUrl}}/register
