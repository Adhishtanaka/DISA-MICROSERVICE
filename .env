# =============================================================================
# DISA Microservice — Environment Variables
# Safe to commit: all values are local-dev defaults, no real secrets.
# Override any value in your shell before running docker-compose.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=dev-secret-key-change-in-production-at-least-32-chars

# ── External API Keys ─────────────────────────────────────────────────────────
# Used by assessment-service for AI-assisted damage analysis
GEMINI_API_KEY=your-gemini-api-key-here
