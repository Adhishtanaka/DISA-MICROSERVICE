# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

DB_URL=jdbc:postgresql://<your-host>/<your-db>?sslmode=require
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# RabbitMQ — use the shared broker credentials (e.g. the auth-service RabbitMQ instance)
RABBITMQ_HOST=your_rabbitmq_host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_username
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_VIRTUAL_HOST=/

# Incident Service URL — base URL of the incident service
# Docker Compose (local): http://incident-service:8083
# Cloud / external: https://<your-incident-service-hostname>
INCIDENT_SERVICE_URL=http://incident-service:8083

SERVER_PORT=8086
